generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Wine {
  id          String @id @default(uuid())
  name        String
  description String

  color        String
  sweetness    String
  volume       Float
  alcohol      String
  grapeVariety String
  country      String

  inStock Boolean @default(true)
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  email    String? @unique
  password String
}

model Post {
  id        String   @id @default(uuid())
  title     String // Додали заголовок
  content   String // поле TEXT
  createdAt DateTime @default(now()) // дата створення, щоб сортувати пости
}
